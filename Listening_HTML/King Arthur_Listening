    navigator.clipboard.write([clipboardItem]).then(() => {
      alert(successMessage);
    });
  } catch (err) {
    navigator.clipboard.writeText(plainTextString).then(() => {
      alert("Copied as plain text (Rich text not supported by your browser).");
    });
  }
}

