    function copyToClipboardRich(htmlString, plainTextString, successMessage) {
      try {
        const item = new ClipboardItem({
          "text/html": new Blob([htmlString], { type: "text/html" }),
          "text/plain": new Blob([plainTextString], { type: "text/plain" })
        });
        navigator.clipboard.write([item]).then(() => alert(successMessage));
      } catch (err) {
        navigator.clipboard.writeText(plainTextString).then(() => {
          alert("Copied as plain text (rich text not supported).");
        });
      }
    }

